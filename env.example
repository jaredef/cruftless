# cruftless local script environment.
# Copy this file to env.local and adjust paths for your machine.

# Repository root. Scripts auto-detect this when unset.
CRUFTLESS_ROOT=/path/to/cruftless

# Runtime binaries used by parity, benchmark, and probe scripts.
CRUFT_BIN=/path/to/cruftless/target/release/cruft
BUN_BIN=bun
NODE_BIN=node

# Optional upstream Test262 checkout used by scripts/test262-sample/* and
# legacy/host-rquickjs/tests/test262/run.sh.
T262_ROOT=/path/to/test262

# Differential production-test work dirs.
PROD_SANDBOX=/tmp/cruftless-diff-prod-sandbox
RESULTS_DIR=/tmp/cruftless-diff-prod-results

# ArkType deviation probe install root.
PROBE_ROOT=/tmp/cruftless-ak-probe

# Cross-runtime-bench output root.
CRUFTLESS_CROSS_RUNTIME_RESULTS_ROOT=/tmp/cruftless-cross-runtime-bench-results

# Test262 sample runner local binary cache. Useful on machines where target/
# is on slower removable storage.
LOCAL_CRUFT=/tmp/cruftless-local-bin/cruft
