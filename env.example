# cruftless local script environment.
# Copy this file to env.local and adjust paths for your machine.

# Repository root. Scripts auto-detect this when unset.
CRUFTLESS_ROOT=/path/to/cruftless

# Runtime binaries used by parity, benchmark, and probe scripts.
CRUFT_BIN=/path/to/cruftless/target/release/cruft
BUN_BIN=bun
NODE_BIN=node

# Optional upstream Test262 checkout used by scripts/test262-sample/* and
# legacy/host-rquickjs/tests/test262/run.sh.
T262_ROOT=/path/to/test262

# Sidecar root for generated test artifacts. Keep this outside the repo so
# benchmark and conformance runs do not dirty the working tree.
CRUFTLESS_SIDECAR=/tmp/cruftless-sidecar
TEST_ARTIFACTS_DIR=/tmp/cruftless-sidecar/results

# Differential production-test work dirs.
PROD_SANDBOX=/tmp/cruftless-diff-prod-sandbox
RESULTS_DIR=/tmp/cruftless-sidecar/results/diff-prod

# ArkType deviation probe install root.
PROBE_ROOT=/tmp/cruftless-ak-probe

# Test262 and cross-runtime-bench output roots.
CRUFTLESS_TEST262_RESULTS_ROOT=/tmp/cruftless-sidecar/results
CRUFTLESS_CROSS_RUNTIME_RESULTS_ROOT=/tmp/cruftless-sidecar/results/cross-runtime-bench

# Test262 sample runner local binary cache. Useful on machines where target/
# is on slower removable storage.
LOCAL_CRUFT=/tmp/cruftless-local-bin/cruft

# Cybernetic Agentic Communication Protocol (CAACP) authentication.
# Per apparatus/docs/cybernetic-agentic-communication-protocol.md +
# apparatus/docs/agent-init-protocol.md.
#
# CAACP_TOKEN is the legacy admin/shared token (also the value of
# CAACP_TOKEN_VERIFIER on the jaredfoy.com server). Used by the local
# sidecar at apparatus/caacp-server/ to register agents with jaredfoy.com,
# and by apparatus/scripts/caacp.sh for direct-to-endpoint operations
# (legacy path; sidecar is preferred going forward).
CAACP_TOKEN=

# CAACP endpoint URL override. Default is https://jaredfoy.com/api/caacp/v1.
CAACP_ENDPOINT=https://jaredfoy.com/api/caacp/v1

# Singleton per-role tokens for the four appointed governance/service
# roles. Each is registered once via the admin token (POST /register
# with role: helmsman|arbiter|watcher|deputy). The role-load skills
# load the matching variable on session entry to authenticate against
# the sidecar's /local/register endpoint and (via the sidecar) the
# jaredfoy.com endpoint with role-bound identity.
CAACP_TOKEN_HELMSMAN=
CAACP_TOKEN_ARBITER=
CAACP_TOKEN_WATCHER=
CAACP_TOKEN_DEPUTY=

# Substrate-resolver tokens are registered per-session-instance via
# the local sidecar's POST /local/register, not via env vars; each
# Claude Code / Codex session gets its own token at runtime per the
# agent init protocol §II.

# Local CAACP sidecar configuration (apparatus/caacp-server/server.ts).
# CAACP_SIDECAR_PORT default 7777; CAACP_SIDECAR_HOST default 127.0.0.1.
# CAACP_POLL_INTERVAL_MS default 5000.
CAACP_SIDECAR_PORT=7777
CAACP_SIDECAR_HOST=127.0.0.1
CAACP_POLL_INTERVAL_MS=5000

# Codex Desktop app-server bridge configuration
# (apparatus/scripts/caacp-codex-app-bridge.mjs). Used when an agent
# session is reachable via Codex Desktop / iOS-controlled remote
# control. The bridge calls turn/start on the configured thread to
# wake it when a new CAACP message arrives. Each per-role bridged
# session needs its own thread id. See agent-init-protocol §V.1.
CODEX_APP_SERVER_WS=ws://<host>:<port>
CODEX_APP_TOKEN_FILE=/home/<user>/.codex/remote-control/ios-token
# CODEX_APP_THREAD_<ROLE>=<uuid> per role bridged via the app-server.
CODEX_APP_THREAD_WATCHER=
CODEX_APP_THREAD_HELMSMAN=
CODEX_APP_THREAD_ARBITER=
CODEX_APP_THREAD_DEPUTY=
